<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.ssfproject.U1G2Controller">
   <children>
      <VBox layoutY="2.0" prefHeight="400.0" prefWidth="600.0" spacing="15.0">
         <children>
            <Label text="Live Unit Monitoring">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>
            <ComboBox fx:id="unitComboBox" prefHeight="26.0" prefWidth="305.0" promptText="Select Unit" />
            <Button mnemonicParsing="false" onAction="#sendInstrictionBOA" text="Send Instruction" />
            <HBox alignment="CENTER_LEFT" prefHeight="62.0" prefWidth="443.0" spacing="15.0">
               <children>
                  <Circle fx:id="alphaCircle" fill="DODGERBLUE" radius="10.0" stroke="BLACK" strokeType="INSIDE" />
                  <Label text="Unit Alpha">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Label>
                  <Label fx:id="alphaStatusLabel" contentDisplay="TOP" text="Status Label" />
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" prefHeight="80.0" prefWidth="560.0" spacing="15.0">
               <children>
                  <Circle fx:id="bravoCircle" fill="DODGERBLUE" radius="10.0" stroke="BLACK" strokeType="INSIDE" />
                  <Label text="Unit Bravo">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Label>
                  <Label fx:id="bravoStatusLabel" text="Status Label" />
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" prefHeight="91.0" prefWidth="560.0" spacing="15.0">
               <children>
                  <Circle fx:id="charlieCircle" fill="DODGERBLUE" radius="10.0" stroke="BLACK" strokeType="INSIDE" />
                  <Label text="Unit Charlie">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Label>
                  <Label fx:id="charlieStatusLabel" text="Status Label" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>
